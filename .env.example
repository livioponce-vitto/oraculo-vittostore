# ── Servidor ──────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Shopify ───────────────────────────────────────────────
SHOPIFY_WEBHOOK_SECRET=your_shopify_webhook_secret_here

# ── WhatsApp (Meta Cloud API) ─────────────────────────────
WHATSAPP_API_ENDPOINT=https://graph.facebook.com/v19.0/YOUR_PHONE_ID/messages
WHATSAPP_API_TOKEN=your_meta_permanent_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# ── Finance Alerts ────────────────────────────────────────
FINANCE_ALERT_TOKEN=your_finance_alert_secret_token_here
FINANCE_ALERT_PHONE=56912345678

# ── Firebase (opcional) ───────────────────────────────────
# FIREBASE_PROJECT_ID=your_project_id
# FIREBASE_CLIENT_EMAIL=your_service_account@project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Base de datos (opcional) ──────────────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/vittostore

# ── CORS Whitelist (opcional, separados por coma) ─────────
# ALLOWED_ORIGINS=https://vittostore.store,https://tu-tienda.myshopify.com