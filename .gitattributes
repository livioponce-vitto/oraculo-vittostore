# Normalize line endings
* text=auto eol=lf

# Force LF for source files
*.js    text eol=lf
*.ts    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.env*  text eol=lf
*.toml  text eol=lf
*.sh    text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.liquid text eol=lf

# Binary files
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary